# Copy this file to .env and fill in real values before running docker compose.
# .env is git-ignored and must NEVER be committed.

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_me_strong_root_password

# Password for the app_user account (must match mongo-init.js first run)
MONGO_APP_PASSWORD=change_me_strong_app_password

# ── JWT signing key (32+ random characters) ──────────────────────────────────
Jwt__Key=change_me_at_least_32_characters_long_random_string

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_admin_password

# ── VAPID push notification keys (optional — leave CHANGE_ME to disable push) ─
# Generate with: npx web-push generate-vapid-keys
Push__VapidPublicKey=CHANGE_ME_VAPID_PUBLIC_KEY
Push__VapidPrivateKey=CHANGE_ME_VAPID_PRIVATE_KEY
Push__VapidSubject=mailto:you@example.com

# ── CORS (comma-separated if multiple) ───────────────────────────────────────
# Set to your server's LAN address and/or public domain
# These override the defaults in appsettings.json at runtime
# Example: Cors__AllowedOrigins__0=http://192.168.1.50:8182
#          Cors__AllowedOrigins__1=https://chat.yourdomain.com
