{
  "MongoDB": {
    "Host": "mongodb",
    "Port": 27017,
    "Database": "chat_db",
    "Username": "app_user",
    "Password": "CHANGE_ME_IN_ENV",
    "AuthSource": "my_app_db"
  },
  "Jwt": {
    "Key": "CHANGE_ME_SET_Jwt__Key_IN_DOTENV_FILE",
    "Issuer": "ChatApp",
    "Audience": "ChatAppUsers",
    "ExpirationHours": 24
  },
  "Push": {
    "VapidPublicKey":  "CHANGE_ME_VAPID_PUBLIC_KEY",
    "VapidPrivateKey": "CHANGE_ME_VAPID_PRIVATE_KEY",
    "VapidSubject":    "mailto:admin@example.com"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8182",
      "https://your-domain.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
